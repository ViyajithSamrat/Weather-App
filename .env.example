# =============================================================================
# Enterprise Weather App — Environment Variable Reference
#
# HOW TO USE:
#   Local development  → copy to .env.local  (gitignored)
#   CI/CD (CodeBuild)  → inject via AWS Secrets Manager / Parameter Store
#   ECS task           → inject via ECS Task Definition secretsmanager refs
#
# SECURITY RULES:
#   ❌ NEVER commit a file containing real values to version control
#   ❌ NEVER hardcode secrets in Dockerfile, buildspec.yml, or CloudFormation
#   ✅ All secrets must live in AWS Secrets Manager (prod/staging) or
#      AWS SSM Parameter Store (dev/qa)
# =============================================================================

# -----------------------------------------------------------------------------
# OpenWeather API (server-side ONLY — never exposed to the browser)
# Get yours: https://openweathermap.org/api
# AWS path:  /weather-app/<env>/OPENWEATHER_API_KEY  (SSM SecureString)
# -----------------------------------------------------------------------------
OPENWEATHER_API_KEY=your_openweather_api_key_here

# -----------------------------------------------------------------------------
# Application settings
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3000
NEXT_TELEMETRY_DISABLED=1

# -----------------------------------------------------------------------------
# AWS (populated automatically in CodeBuild / ECS — set locally only if needed)
# -----------------------------------------------------------------------------
# AWS_REGION=us-east-1
# AWS_ACCOUNT_ID=123456789012
