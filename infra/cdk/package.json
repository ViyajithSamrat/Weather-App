    "destroy": "cdk destroy --all --force"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "aws-cdk": "2.173.4",
    "ts-node": "^10.9.2",
    "typescript": "~5.6.3"
  },
  "dependencies": {
    "aws-cdk-lib": "2.173.4",
    "constructs": "^10.4.2"
  }
}
