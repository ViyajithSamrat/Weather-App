{
  "name": "weather-app-cdk",
  "version": "1.0.0",
  "description": "Enterprise Weather App - AWS CDK IaC (dev environment, free-tier)",
  "bin": {
    "weather-app": "bin/weather-app.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "synth": "cdk synth",
    "diff": "cdk diff",
