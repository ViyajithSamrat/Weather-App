# ── Next.js (root + any subdir like weather-app/) ─────────────────────────────
**/.next/
**/out/
**/build/
**/next-env.d.ts
**/*.tsbuildinfo

# ── Dependencies (root + any subdir) ──────────────────────────────────────────
**/node_modules/
**/.pnp/
**/.pnp.*

# ── Environment secrets — NEVER commit these ──────────────────────────────────
.env
.env.*
!.env.example
**/.env
**/.env.*
!**/.env.example

# ── OS / Editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.pem
.vscode/
.idea/

# ── Claude Code session data ──────────────────────────────────────────────────
.claude/

# ── Logs ──────────────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Misc ──────────────────────────────────────────────────────────────────────
.vercel/
coverage/
